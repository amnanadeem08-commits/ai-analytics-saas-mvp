APP_NAME=AI Analytics SaaS MVP
API_BASE_URL=http://127.0.0.1:8000
MAX_UPLOAD_SIZE_MB=25

# Payment gateway: internal (default/dev) | stripe
BILLING_GATEWAY=internal
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# BILLING_CHECKOUT_SUCCESS_URL=http://127.0.0.1:8501/?billing=success
# BILLING_CHECKOUT_CANCEL_URL=http://127.0.0.1:8501/?billing=cancel

# Commercial stores follow STORAGE_BACKEND unless overridden:
# COMMERCIAL_STORAGE_BACKEND=memory|sqlite|postgres
# STORAGE_BACKEND=memory
# STORAGE_BACKEND=sqlite
# DATABASE_URL=sqlite:///./data/app.db

# Object storage (files/artifacts). Prefer OBJECT_STORAGE_BACKEND.
# OBJECT_STORAGE_BACKEND=local
# OBJECT_STORAGE_BACKEND=s3
# S3_BUCKET=databot-artifacts
# S3_REGION=us-east-1
# S3_ENDPOINT=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
