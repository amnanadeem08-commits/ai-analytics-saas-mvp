APP_NAME=AI Analytics SaaS MVP
API_BASE_URL=http://127.0.0.1:8000
MAX_UPLOAD_SIZE_MB=25

# Security — REQUIRED in production (≥32 chars). Generate:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# Prefer AUTH_JWT_SECRET; JWT_SECRET is an accepted alias.
# Production (APP_ENV=production) refuses to boot with missing/weak secrets.
# AUTH_JWT_SECRET=
# JWT_SECRET=

# CORS — unset in development → localhost defaults.
# Set CORS_ALLOWED_ORIGINS=* for fully open local CORS.
# Production REQUIRES explicit origins and refuses * (KI-006).
# CORS_ALLOWED_ORIGINS=http://localhost:8501,http://127.0.0.1:8501

# Payment gateway: internal (default/dev) | stripe
BILLING_GATEWAY=internal
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# BILLING_CHECKOUT_SUCCESS_URL=http://127.0.0.1:8501/?billing=success
# BILLING_CHECKOUT_CANCEL_URL=http://127.0.0.1:8501/?billing=cancel

# Commercial stores follow STORAGE_BACKEND unless overridden:
# COMMERCIAL_STORAGE_BACKEND=memory|sqlite|postgres
# STORAGE_BACKEND=memory
# STORAGE_BACKEND=sqlite
# DATABASE_URL=sqlite:///./data/app.db

# Object storage (files/artifacts). Prefer OBJECT_STORAGE_BACKEND.
# OBJECT_STORAGE_BACKEND=local
# OBJECT_STORAGE_BACKEND=s3
# S3_BUCKET=databot-artifacts
# S3_REGION=us-east-1
# S3_ENDPOINT=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Storage object metadata catalog (KI-009). Default: file under STORAGE_ROOT_DIR.
# When STORAGE_BACKEND=sqlite|postgres, SQLAlchemy catalog is used automatically.
# STORAGE_METADATA_BACKEND=file|sqlalchemy|memory
# STORAGE_ROOT_DIR=./data/storage
