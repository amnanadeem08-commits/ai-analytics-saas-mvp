# Data Bot AI — production Compose environment template (KI-006 / KI-007)
# Usage:
#   1. Copy to docker/.env.production and fill secrets
#   2. cd docker
#   3. docker compose --env-file .env.production --profile prod up --build -d
#   4. python verify_prod_compose.py --live   (optional health probes)
#
# NEVER commit real secrets. Generate JWT:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"

APP_NAME=AI Analytics SaaS MVP
API_VERSION=1.0.0
APP_ENV=production

LOG_LEVEL=INFO
LOG_FORMAT=json

# REQUIRED — unique ≥32 characters (production fail-fast)
AUTH_JWT_SECRET=REPLACE_WITH_TOKEN_URLSAFE_48
JWT_SECRET=REPLACE_WITH_TOKEN_URLSAFE_48

# REQUIRED — explicit origins only (no wildcard *)
CORS_ALLOWED_ORIGINS=http://localhost:8501,http://127.0.0.1:8501
CORS_ALLOW_CREDENTIALS=false

STORAGE_BACKEND=postgres
DATABASE_URL=postgresql://databot:databot@postgres:5432/databot

QUEUE_BACKEND=redis
REDIS_URL=redis://redis:6379/0
WORKER_ENABLED=true

OBJECT_STORAGE_BACKEND=local
STORAGE_ROOT_DIR=/app/data/storage
STORAGE_METADATA_BACKEND=sqlalchemy

MAX_UPLOAD_SIZE_MB=200

RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCKOUT_SECONDS=300
CSRF_ENABLED=false
SECURITY_HSTS_ENABLED=true
SECURITY_CSP_ENABLED=true

API_BASE_URL=http://backend:8000

METRICS_ENABLED=true
TRACING_ENABLED=true

# Billing remains internal until Stripe keys are configured
BILLING_GATEWAY=internal
