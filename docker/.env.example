# Data Bot AI — environment template (Sprint 8.5)
# Copy to .env and adjust for local / production profiles.

APP_NAME=AI Analytics SaaS MVP
API_VERSION=1.0.0

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Security — REQUIRED in production (≥32 chars, unique). Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# Prefer AUTH_JWT_SECRET; JWT_SECRET / SECRET_KEY are accepted aliases.
# APP_ENV=production refuses to start without a strong secret (KI-007).
APP_ENV=development
# AUTH_JWT_SECRET=
JWT_SECRET=local-compose-dev-secret-not-for-production-use
SECRET_KEY=

# Database persistence backend (memory | postgres | sqlite)
STORAGE_BACKEND=postgres
DATABASE_URL=postgresql://databot:databot@postgres:5432/databot

# Queue / worker
QUEUE_BACKEND=redis
REDIS_URL=redis://redis:6379/0
WORKER_ENABLED=true

# Object storage provider (local | s3). Prefer OBJECT_STORAGE_BACKEND so it
# does not collide with STORAGE_BACKEND used for DB (memory|sqlite|postgres).
OBJECT_STORAGE_BACKEND=local
STORAGE_ROOT_DIR=/app/data/storage
# Durable object catalog: file | sqlalchemy | memory (KI-009)
# Defaults to sqlalchemy when STORAGE_BACKEND is sqlite/postgres; otherwise file.
# STORAGE_METADATA_BACKEND=sqlalchemy
# S3 / MinIO (when OBJECT_STORAGE_BACKEND=s3)
# S3_BUCKET=databot-artifacts
# S3_REGION=us-east-1
# S3_ENDPOINT=https://s3.amazonaws.com
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

# Upload limits
MAX_UPLOAD_SIZE_MB=200

# CORS — development defaults to localhost when unset; use * only for open local CORS.
# Production (APP_ENV=production) REQUIRES explicit origins and refuses * (KI-006).
# CORS_ALLOWED_ORIGINS=http://localhost:8501,http://127.0.0.1:8501
# CORS_ALLOWED_ORIGINS=*
CORS_ALLOW_CREDENTIALS=false

# Security hardening (Sprint 8.7)
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCKOUT_SECONDS=300
CSRF_ENABLED=false
SECURITY_HSTS_ENABLED=false
SECURITY_CSP_ENABLED=true

# Frontend
API_BASE_URL=http://backend:8000

# Observability
METRICS_ENABLED=true
TRACING_ENABLED=true
